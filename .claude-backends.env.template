# Claude Code Backend Configuration — TEMPLATE
# Live file lives at ~/.vibe/claude-backends.env (synced via vibe-config Syncthing folder)
# This template documents the SHAPE only. Real values get filled in once on any device,
# then sync everywhere.

# Self-Hosted via LiteLLM proxy (DigitalFacility)
LOCAL_BASE_URL="https://ai.digitalfacility.io/api"
LOCAL_AUTH_TOKEN="REPLACE_WITH_YOUR_DF_TOKEN"
LOCAL_MODEL="mistral-medium"
LOCAL_MODEL_NAME="Mistral Medium 1M (Self-Hosted)"

# Ollama (local machine — only if you run Ollama on this device)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_AUTH_TOKEN="ollama"
OLLAMA_MODEL="devstral"
OLLAMA_MODEL_NAME="Devstral (Ollama Local)"

# Mistral Vibe (Official API via DF proxy)
VIBE_API_AVAILABLE=true
VIBE_API_KEY_FILE="$HOME/.vibe/.env"
VIBE_BASE_URL="${LOCAL_BASE_URL}"
