#!/usr/bin/env bash
# wg-labyrinth — multi-hop WireGuard chain CLI for macOS.
# Mac is the entry hop; 2 containers (middle, exit) form the rest of the chain.
# State lives in ~/.config/labyrinth; this script in ~/Git/dotfiles/macos/wg-labyrinth.
#
# Encodes every macOS-specific rule from the irregularpedia wireguard-in-containers
# page (sysctls block, Table=off, dev-only routes, asymmetric AllowedIPs).
#
# Usage: labyrinth {init|up|down|status|test|clean|selectivity|logs|exec} [args...]

set -euo pipefail

# ---------------------------------------------------------------------------- paths
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_DIR="${LABYRINTH_STATE_DIR:-$HOME/.config/labyrinth}"
KEYS_DIR="$STATE_DIR/keys"
RENDERED_DIR="$STATE_DIR/rendered"
COMPOSE_FILE="$RENDERED_DIR/docker-compose.yml"

# ---------------------------------------------------------------------------- log
log()  { printf '%s [labyrinth] %s\n'                       "$(date +%H:%M:%S)" "$*"; }
warn() { printf '%s \033[33m[labyrinth WARN]\033[0m %s\n'    "$(date +%H:%M:%S)" "$*" >&2; }
err()  { printf '%s \033[31m[labyrinth ERR]\033[0m %s\n'     "$(date +%H:%M:%S)" "$*" >&2; }
ok()   { printf '%s \033[32m[labyrinth OK]\033[0m %s\n'      "$(date +%H:%M:%S)" "$*"; }
die()  { err "$*"; exit 1; }

# ---------------------------------------------------------------------------- pre-flight
require_tool() {
  command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1${2:+ ($2)}"
}

source_hopsconf() {
  local f="$SCRIPT_DIR/hops.conf"
  [ -r "$f" ] || die "hops.conf not found at $f"
  # shellcheck disable=SC1090
  . "$f"
  : "${LABYRINTH_IMAGE_TAG:?}"
  : "${LABYRINTH_NETWORK_NAME:?}"
  : "${LABYRINTH_SUBNET:?}"
  : "${LABYRINTH_MIDDLE_BRIDGE_IP:?}"
  : "${LABYRINTH_EXIT_BRIDGE_IP:?}"
  : "${LABYRINTH_MAC_WG_IP:?}"
  : "${LABYRINTH_MAC_WG_NET:?}"
  : "${LABYRINTH_MIDDLE_WG_IP:?}"
  : "${LABYRINTH_MIDDLE_WG_NET:?}"
  : "${LABYRINTH_EXIT_WG_IP:?}"
  : "${LABYRINTH_EXIT_WG_NET:?}"
  : "${LABYRINTH_MIDDLE_PORT:?}"
  : "${LABYRINTH_EXIT_PORT:?}"
  : "${LABYRINTH_MAC_IF:?}"
  : "${LABYRINTH_SELECTIVITY:?}"
  : "${LABYRINTH_SELECTIVE_DESTS:?}"
  : "${LABYRINTH_PERSISTENT_KEEPALIVE:?}"
  MAC_CONF="$RENDERED_DIR/${LABYRINTH_MAC_IF}.conf"
}

preflight() {
  require_tool docker "install Docker Desktop"
  require_tool wg     "brew install wireguard-tools"
  require_tool wg-quick "brew install wireguard-tools"
  docker info >/dev/null 2>&1 || die "docker daemon not running (start Docker Desktop)"
  source_hopsconf
  mkdir -p "$STATE_DIR" "$KEYS_DIR" "$RENDERED_DIR"
  chmod 700 "$KEYS_DIR"
}

check_port_free() {
  local port=$1 attempts=10 owner
  while [ $attempts -gt 0 ]; do
    owner=$( { lsof -nP -iUDP:"$port" 2>/dev/null || true; } | awk 'NR==2 {print $1}')
    if [ -z "$owner" ]; then return 0; fi
    # com.docker.* lingers briefly after compose down — give it a few seconds before giving up.
    if [[ "$owner" != com.docke* ]]; then
      die "UDP port $port already in use by '$owner'. Change LABYRINTH_MIDDLE_PORT in hops.conf."
    fi
    sleep 1
    attempts=$((attempts - 1))
  done
  warn "UDP port $port still held by Docker after wait; trying anyway"
}

# ---------------------------------------------------------------------------- keys
gen_key() {
  local hop=$1
  local priv="$KEYS_DIR/$hop.key"
  local pub="$KEYS_DIR/$hop.pub"
  if [ ! -s "$priv" ]; then
    ( umask 077 && wg genkey > "$priv" )
    log "generated $hop private key"
  fi
  if [ ! -s "$pub" ] || [ "$priv" -nt "$pub" ]; then
    ( umask 077 && wg pubkey < "$priv" > "$pub" )
    log "derived $hop public key"
  fi
}

# ---------------------------------------------------------------------------- render: middle
render_wg_middle() {
  local out="$RENDERED_DIR/wg0-middle.conf"
  local priv mac_pub exit_pub
  priv=$(cat "$KEYS_DIR/middle.key")
  mac_pub=$(cat "$KEYS_DIR/mac.pub")
  exit_pub=$(cat "$KEYS_DIR/exit.pub")
  # NOTE: wg-quick parses line-by-line and does NOT join '\'-continued lines.
  # Use one directive per line. Multiple PostUp/PostDown lines run in order.
  cat > "$out" <<EOF
# Generated by labyrinth — do not edit manually.
# Middle hop: forwards Mac traffic through to exit, return-path for Mac.

[Interface]
PrivateKey = $priv
Address = $LABYRINTH_MIDDLE_WG_IP/24
ListenPort = $LABYRINTH_MIDDLE_PORT
# Table=off: wg-quick won't auto-route AllowedIPs=0/0; we manage routes in PostUp.
# Without this on Docker Desktop, wg-quick tries sysctl -q net.ipv4.conf.all.src_valid_mark=1
# against read-only /proc/sys and the container restart-loops.
Table = off
# rp_filter inherits 2 from net.ipv4.conf.default (compose sysctls) at wg0 creation; kernel
# does MAX(.all, wg0). /proc/sys is read-only here so PostUp 'sysctl -w' would fail anyway.
#
# Routing-table split (replicates wg-quick Table=auto WITHOUT calling its broken sysctl):
#   - wg0's encrypted-UDP egress is marked with fwmark 51820 by WireGuard itself.
#   - Custom routing table 51820 has 'default dev wg0' (catches all NON-marked traffic).
#   - 'ip rule add not fwmark 51820 table 51820' sends non-marked traffic to that table.
#   - Marked traffic (wg0's own UDP, including handshake responses to Mac via Docker bridge)
#     uses the MAIN table → bridge default via eth0 → no routing loop.
PostUp = wg set %i fwmark 51820
PostUp = ip rule add not fwmark 51820 table 51820
PostUp = ip rule add table main suppress_prefixlength 0
PostUp = ip route add default dev %i table 51820
PostUp = iptables -A FORWARD -i %i -j ACCEPT
PostUp = iptables -A FORWARD -o %i -j ACCEPT
PostUp = iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = ip rule del not fwmark 51820 table 51820
PostDown = ip rule del table main suppress_prefixlength 0
PostDown = ip route del default dev %i table 51820
PostDown = iptables -D FORWARD -i %i -j ACCEPT
PostDown = iptables -D FORWARD -o %i -j ACCEPT
PostDown = iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

[Peer]
# Mac (entry hop) — return-path only, narrow /24
PublicKey = $mac_pub
AllowedIPs = $LABYRINTH_MAC_WG_NET

[Peer]
# Exit — catch-all forward; cryptokey routing picks this peer for anything
# that doesn't match the Mac peer's narrower /24.
PublicKey = $exit_pub
AllowedIPs = 0.0.0.0/0
Endpoint = ${LABYRINTH_EXIT_BRIDGE_IP}:${LABYRINTH_EXIT_PORT}
PersistentKeepalive = $LABYRINTH_PERSISTENT_KEEPALIVE
EOF
  chmod 600 "$out"
}

# ---------------------------------------------------------------------------- render: exit
render_wg_exit() {
  local out="$RENDERED_DIR/wg0-exit.conf"
  local priv middle_pub
  priv=$(cat "$KEYS_DIR/exit.key")
  middle_pub=$(cat "$KEYS_DIR/middle.pub")
  cat > "$out" <<EOF
# Generated by labyrinth — do not edit manually.
# Exit hop: real internet via Docker bridge eth0; never routes traffic forward.

[Interface]
PrivateKey = $priv
Address = $LABYRINTH_EXIT_WG_IP/24
ListenPort = $LABYRINTH_EXIT_PORT
Table = off

# Add explicit routes for chain return-path subnets via wg0 (wg-quick won't with Table=off).
# Keep Docker-bridge default route; only return packets bound for the chain hit wg0.
# rp_filter inherited from .default via compose sysctls — see middle config note.
PostUp = ip route replace $LABYRINTH_MAC_WG_NET dev %i
PostUp = ip route replace $LABYRINTH_MIDDLE_WG_NET dev %i
PostUp = iptables -A FORWARD -i %i -o eth0 -j ACCEPT
PostUp = iptables -A FORWARD -i eth0 -o %i -m state --state RELATED,ESTABLISHED -j ACCEPT
PostUp = iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = ip route del $LABYRINTH_MAC_WG_NET dev %i
PostDown = ip route del $LABYRINTH_MIDDLE_WG_NET dev %i
PostDown = iptables -D FORWARD -i %i -o eth0 -j ACCEPT
PostDown = iptables -D FORWARD -i eth0 -o %i -m state --state RELATED,ESTABLISHED -j ACCEPT
PostDown = iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

[Peer]
# Middle — ONLY peer, AllowedIPs covers the upstream chain /24s; NOT 0.0.0.0/0
# (catch-all on exit would loop replies back into the tunnel instead of out eth0).
PublicKey = $middle_pub
AllowedIPs = $LABYRINTH_MAC_WG_NET, $LABYRINTH_MIDDLE_WG_NET
PersistentKeepalive = $LABYRINTH_PERSISTENT_KEEPALIVE
EOF
  chmod 600 "$out"
}

# ---------------------------------------------------------------------------- render: Mac
mac_allowed_ips() {
  case "${LABYRINTH_SELECTIVITY:-off}" in
    all)  echo "0.0.0.0/0, ::/0" ;;
    destinations|dests) echo "$LABYRINTH_SELECTIVE_DESTS" ;;
    off)  echo "$LABYRINTH_MIDDLE_WG_NET" ;;  # safe no-op: only chain subnet, no internet routes
    *)    die "invalid LABYRINTH_SELECTIVITY: $LABYRINTH_SELECTIVITY (want: all|destinations|off)" ;;
  esac
}

render_wg_mac() {
  local priv middle_pub allowed mode lan_ip
  priv=$(cat "$KEYS_DIR/mac.key")
  middle_pub=$(cat "$KEYS_DIR/middle.pub")
  mode="${LABYRINTH_SELECTIVITY:-off}"
  allowed="$(mac_allowed_ips)"
  lan_ip=$(get_mac_lan_ip) || die "couldn't detect Mac LAN IP (no default IPv4 route?)"
  # Why not 127.0.0.1: wg-quick on macOS auto-adds 'route add <endpoint-ip> -gateway <default-gw>'
  # to prevent its own UDP from looping into the tunnel. For a 127.0.0.1 endpoint, that
  # bypass route redirects loopback to the LAN gateway, which fails (router can't deliver
  # back to 127.0.0.1). Using the Mac's actual LAN IP works because (a) the bypass route is
  # legitimate LAN routing, and (b) the kernel hairpins packets to our own LAN IP back into
  # the local stack, where the Docker-published port (also bound to the same LAN IP) catches them.
  cat > "$MAC_CONF" <<EOF
# Generated by labyrinth — do not edit manually.
# Mac-side WireGuard config; brings up via wg-quick on macOS (userspace wireguard-go).
# Current selectivity mode: $mode
# Endpoint uses Mac LAN IP ($lan_ip), not 127.0.0.1, because of wg-quick's loopback bypass quirk.

[Interface]
PrivateKey = $priv
Address = $LABYRINTH_MAC_WG_IP/24

[Peer]
PublicKey = $middle_pub
Endpoint = ${lan_ip}:${LABYRINTH_MIDDLE_PORT}
AllowedIPs = $allowed
PersistentKeepalive = $LABYRINTH_PERSISTENT_KEEPALIVE
EOF
  chmod 600 "$MAC_CONF"
}

# ---------------------------------------------------------------------------- render: compose
render_compose() {
  local lan_ip
  lan_ip=$(get_mac_lan_ip) || die "couldn't detect Mac LAN IP for compose port bind"
  cat > "$COMPOSE_FILE" <<EOF
# Generated by labyrinth — do not edit manually.
# Bound to Mac LAN IP $lan_ip (not 0.0.0.0) so the wg port isn't exposed to the LAN at large.

services:
  middle:
    image: $LABYRINTH_IMAGE_TAG
    container_name: labyrinth-middle
    restart: "no"
    cap_add:
      - NET_ADMIN
    sysctls:
      net.ipv4.ip_forward: "1"
      net.ipv4.conf.all.src_valid_mark: "1"
      net.ipv4.conf.all.rp_filter: "2"
      net.ipv4.conf.default.rp_filter: "2"
    ports:
      - "${lan_ip}:${LABYRINTH_MIDDLE_PORT}:${LABYRINTH_MIDDLE_PORT}/udp"
    volumes:
      - $RENDERED_DIR/wg0-middle.conf:/etc/wireguard/wg0.conf:ro
    environment:
      HOP_NAME: middle
      WG_CONF: /etc/wireguard/wg0.conf
    networks:
      labyrinth:
        ipv4_address: $LABYRINTH_MIDDLE_BRIDGE_IP

  exit:
    image: $LABYRINTH_IMAGE_TAG
    container_name: labyrinth-exit
    restart: "no"
    cap_add:
      - NET_ADMIN
    sysctls:
      net.ipv4.ip_forward: "1"
      net.ipv4.conf.all.src_valid_mark: "1"
      net.ipv4.conf.all.rp_filter: "2"
      net.ipv4.conf.default.rp_filter: "2"
    volumes:
      - $RENDERED_DIR/wg0-exit.conf:/etc/wireguard/wg0.conf:ro
    environment:
      HOP_NAME: exit
      WG_CONF: /etc/wireguard/wg0.conf
    networks:
      labyrinth:
        ipv4_address: $LABYRINTH_EXIT_BRIDGE_IP

networks:
  labyrinth:
    name: $LABYRINTH_NETWORK_NAME
    driver: bridge
    ipam:
      config:
        - subnet: $LABYRINTH_SUBNET
EOF
}

# ---------------------------------------------------------------------------- helpers
dc() { docker compose -f "$COMPOSE_FILE" "$@"; }

detect_utun() {
  # Find which utun device holds the Mac's wg IP. No sudo needed.
  local ip="$LABYRINTH_MAC_WG_IP"
  local iface
  iface=$(ifconfig 2>/dev/null | awk -v ip="$ip" '
    /^utun[0-9]+:/   { dev=$1; sub(":","",dev); next }
    /^[a-z]+[0-9]+:/ { dev="" }
    dev != "" && $0 ~ "inet "ip" " { print dev; exit }
  ')
  [ -n "$iface" ] || return 1
  echo "$iface"
}

mac_wg_up() {
  # True if Mac wg interface exists with our address. No sudo needed (unlike wg show).
  ifconfig 2>/dev/null | grep -q "inet ${LABYRINTH_MAC_WG_IP} "
}

get_mac_lan_ip() {
  # Return the IP of the interface that owns the default IPv4 route.
  local iface ip
  iface=$(route -n get default 2>/dev/null | awk '/interface:/ {print $2}')
  [ -n "$iface" ] || return 1
  ip=$(ifconfig "$iface" 2>/dev/null | awk '/inet / && $2 !~ /^127\./ {print $2; exit}')
  [ -n "$ip" ] || return 1
  echo "$ip"
}

# ---------------------------------------------------------------------------- cmd: init
cmd_init() {
  log "init: generating keys + rendering configs"
  gen_key mac
  gen_key middle
  gen_key exit
  render_wg_middle
  render_wg_exit
  render_wg_mac
  render_compose
  ok "init complete; configs in $RENDERED_DIR"
}

# ---------------------------------------------------------------------------- cmd: build
cmd_build() {
  log "build: docker build $LABYRINTH_IMAGE_TAG"
  docker build -t "$LABYRINTH_IMAGE_TAG" "$SCRIPT_DIR" >/dev/null
  ok "image built"
}

# ---------------------------------------------------------------------------- cmd: up
wait_for_container_handshake() {
  local hop=$1
  local timeout=${2:-30}
  local elapsed=0
  while [ $elapsed -lt $timeout ]; do
    local ts
    ts=$({ dc exec -T "$hop" wg show wg0 latest-handshakes 2>/dev/null || true; } \
         | awk '{print $2}' | sort -n | tail -1)
    case "$ts" in
      ''|*[!0-9]*) ;;  # empty or non-numeric: not yet ready
      *)
        if [ "$ts" -gt 0 ]; then
          local age=$(( $(date +%s) - ts ))
          log "$hop: handshake ${age}s ago"
          return 0
        fi
        ;;
    esac
    sleep 1
    elapsed=$((elapsed + 1))
  done
  return 1
}

cmd_up() {
  check_port_free "$LABYRINTH_MIDDLE_PORT"
  cmd_init >/dev/null
  cmd_build
  log "up: docker compose up -d"
  dc up -d
  log "waiting for middle↔exit handshake (PersistentKeepalive will trigger it)"
  if ! wait_for_container_handshake exit 45; then
    err "exit never handshook with middle. Recent logs:"
    dc logs --tail 30 exit middle
    die "chain didn't form"
  fi
  ok "chain up: middle ↔ exit handshake established"

  if [ "$LABYRINTH_SELECTIVITY" = "off" ]; then
    warn "SELECTIVITY=off — Mac wg interface NOT brought up; chain reachable only via 'docker exec'"
    warn "  to route Mac traffic through chain: labyrinth selectivity all  (or: destinations)"
  else
    cmd_selectivity_apply "$LABYRINTH_SELECTIVITY"
  fi

  if [ "${LABYRINTH_VERIFY_ON_UP:-true}" = "true" ]; then
    cmd_test
  fi
}

# ---------------------------------------------------------------------------- cmd: down
cmd_down() {
  if mac_wg_up; then
    log "down: wg-quick down $LABYRINTH_MAC_IF"
    wg-quick down "$MAC_CONF" >/dev/null 2>&1 || warn "wg-quick down returned nonzero (ignoring)"
  fi
  if [ -f "$COMPOSE_FILE" ]; then
    log "down: docker compose down"
    dc down --remove-orphans >/dev/null 2>&1 || true
  fi
  ok "chain down (state preserved in $STATE_DIR)"
}

# ---------------------------------------------------------------------------- cmd: clean
cmd_clean() {
  cmd_down
  if [ -d "$STATE_DIR" ]; then
    log "clean: rm -rf $STATE_DIR"
    rm -rf "$STATE_DIR"
  fi
  if docker image inspect "$LABYRINTH_IMAGE_TAG" >/dev/null 2>&1; then
    log "clean: docker rmi $LABYRINTH_IMAGE_TAG"
    docker rmi "$LABYRINTH_IMAGE_TAG" >/dev/null 2>&1 || true
  fi
  ok "clean done — state and image removed"
}

# ---------------------------------------------------------------------------- cmd: selectivity
cmd_selectivity_apply() {
  local mode=${1:-${LABYRINTH_SELECTIVITY:-off}}
  case "$mode" in
    off)
      if mac_wg_up; then
        log "selectivity: off — bringing wg down on Mac"
        wg-quick down "$MAC_CONF" >/dev/null 2>&1 || true
      fi
      ok "selectivity = off (Mac uses normal routing; chain still running for docker-exec testing)"
      ;;
    all|destinations|dests)
      [ "$mode" = "dests" ] && mode="destinations"
      LABYRINTH_SELECTIVITY="$mode" render_wg_mac
      # wg syncconf is the live-reload path on Linux; on macOS it needs the wg socket
      # which is root-only. Bounce wg-quick (briefly disruptive, no sudo).
      if mac_wg_up; then
        log "selectivity: $mode — bouncing wg-quick (~1s gap)"
        wg-quick down "$MAC_CONF" >/dev/null 2>&1 || true
      else
        log "selectivity: $mode — wg-quick up"
      fi
      wg-quick up "$MAC_CONF" >/dev/null
      local utun
      utun=$(detect_utun) && log "Mac utun device: $utun (holds $LABYRINTH_MAC_WG_IP)" || warn "couldn't detect utun"
      ok "selectivity = $mode"
      [ "$mode" = "destinations" ] && log "  routed dsts: $LABYRINTH_SELECTIVE_DESTS"
      ;;
    *) die "unknown selectivity mode: $mode (want: all|destinations|off)" ;;
  esac
}

cmd_selectivity() {
  local mode=${1:-}
  [ -n "$mode" ] || { current_selectivity_print; return; }
  cmd_selectivity_apply "$mode"
}

current_selectivity_print() {
  if mac_wg_up; then
    local utun
    utun=$(detect_utun 2>/dev/null) || utun="?"
    echo "current selectivity: UP on $utun"
    # AllowedIPs is in the rendered config (no sudo needed, unlike wg show).
    grep -E "^AllowedIPs" "$MAC_CONF" 2>/dev/null | head -1 | sed 's/^/  /'
  else
    echo "current selectivity: OFF — Mac wg interface not up"
  fi
}

# ---------------------------------------------------------------------------- cmd: status
cmd_status() {
  echo "=== containers ==="
  if [ -f "$COMPOSE_FILE" ]; then
    dc ps 2>/dev/null || echo "  (compose not running)"
  else
    echo "  (not initialized — run: labyrinth up)"
    return
  fi
  echo
  echo "=== handshakes ==="
  for hop in middle exit; do
    if dc exec -T "$hop" wg show wg0 >/dev/null 2>&1; then
      printf '  %-7s ' "$hop:"
      dc exec -T "$hop" wg show wg0 | grep -E "latest handshake|transfer" | tr '\n' '|' | sed 's/|/  |  /g'
      echo
    else
      echo "  $hop: not running"
    fi
  done
  echo
  echo "=== Mac side ==="
  current_selectivity_print
  if mac_wg_up; then
    echo "  (handshake state requires 'sudo wg show $LABYRINTH_MAC_IF')"
  fi
}

# ---------------------------------------------------------------------------- cmd: test
cmd_test() {
  log "test: full diagnostic recipe"
  local failed=0

  # 1. containers running
  for hop in middle exit; do
    if ! dc ps --status running --services 2>/dev/null | grep -q "^${hop}$"; then
      err "  step 1: $hop NOT running"; failed=1
    fi
  done
  [ $failed -eq 0 ] && ok "  step 1: both containers running"

  # 2. handshakes recent
  for hop in middle exit; do
    local ts age
    ts=$(dc exec -T "$hop" wg show wg0 latest-handshakes 2>/dev/null \
         | awk '{print $2}' | sort -n | tail -1)
    if [ -n "$ts" ] && [ "$ts" -gt 0 ]; then
      age=$(( $(date +%s) - ts ))
      if [ $age -lt 180 ]; then
        ok "  step 2: $hop handshake ${age}s ago"
      else
        err "  step 2: $hop handshake too old (${age}s)"; failed=1
      fi
    else
      err "  step 2: $hop no handshake"; failed=1
    fi
  done

  # 3. middle's default route goes via wg0 (not eth0, which would bypass the chain)
  local middle_def
  middle_def=$(dc exec -T middle ip route show default 2>/dev/null | head -1)
  # Middle's MAIN-table default stays via eth0 (for wg control plane); the chain-forwarding
  # default lives in custom table 51820 with 'default dev wg0'. Both must be present.
  if ! echo "$middle_def" | grep -q "default via .* dev eth0"; then
    err "  step 3a: middle's main default route is NOT via eth0 (handshake responses will loop): $middle_def"; failed=1
  else
    ok "  step 3a: middle main default = via eth0 (wg control plane intact)"
  fi
  local middle_t51820
  middle_t51820=$(dc exec -T middle ip route show table 51820 2>/dev/null | head -1)
  if [[ "$middle_t51820" == default* ]] && echo "$middle_t51820" | grep -q "dev wg0"; then
    ok "  step 3b: middle table 51820 = default dev wg0 (chain forwarding active)"
  else
    err "  step 3b: middle table 51820 missing or wrong: '$middle_t51820'"; failed=1
  fi

  # 4. in-chain traceroute from middle (TCP-based since ICMP is unreliable here)
  local trace
  trace=$(dc exec -T middle traceroute -n -m 4 -w 2 "$LABYRINTH_EXIT_WG_IP" 2>&1 || true)
  if echo "$trace" | head -3 | grep -qE "\s${LABYRINTH_EXIT_WG_IP}\s"; then
    ok "  step 4: traceroute middle→${LABYRINTH_EXIT_WG_IP} reaches exit wg-side"
  else
    err "  step 4: traceroute didn't reach exit wg-side. Output:"
    echo "$trace" | sed 's/^/      /' >&2
    failed=1
  fi

  # 5. end-to-end: curl from middle, tcpdump on exit's eth0
  local pcap_file ip_file
  pcap_file=$(mktemp -t labyrinth-pcap.XXXX)
  ip_file=$(mktemp -t labyrinth-ip.XXXX)
  dc exec -T exit timeout 5 tcpdump -i eth0 -nn -c 5 -l 'tcp port 443' >"$pcap_file" 2>&1 &
  local tcpdump_pid=$!
  sleep 1
  dc exec -T middle curl -s --max-time 5 https://api.ipify.org >"$ip_file" 2>&1 || true
  wait $tcpdump_pid 2>/dev/null || true
  if grep -qE "IP ${LABYRINTH_EXIT_BRIDGE_IP}\.[0-9]+ > [0-9].* Flags \[S\]" "$pcap_file"; then
    ok "  step 5: SYN to api.ipify.org sourced from exit's bridge IP ($LABYRINTH_EXIT_BRIDGE_IP)"
  else
    err "  step 5: no SYN from exit's bridge IP captured. tcpdump output:"
    sed 's/^/      /' "$pcap_file" >&2
    failed=1
  fi
  if [ -s "$ip_file" ] && ! grep -q "error\|Error\|fail\|html" "$ip_file"; then
    log "  step 5: middle's view of WAN IP = $(cat "$ip_file")"
  fi
  rm -f "$pcap_file" "$ip_file"

  # 6. (optional) Mac-side proof if wg is up
  if mac_wg_up; then
    local utun mac_ip
    utun=$(detect_utun) || utun=""
    if [ -n "$utun" ]; then
      mac_ip=$(curl -s --max-time 5 --interface "$utun" https://api.ipify.org 2>&1 || echo "FAIL")
      if [ -n "$mac_ip" ] && ! echo "$mac_ip" | grep -qi "error\|fail\|html\|<"; then
        ok "  step 6: Mac curl via $utun → WAN IP $mac_ip (chain transited)"
      else
        warn "  step 6: Mac curl via $utun did not return a clean IP: $mac_ip"
      fi
    fi
  fi

  if [ $failed -eq 0 ]; then
    ok "all checks passed"
  else
    die "$failed check(s) failed — see above"
  fi
}

# ---------------------------------------------------------------------------- cmd: logs / exec
cmd_logs() {
  if [ -n "${1:-}" ]; then dc logs --tail 50 "$1"; else dc logs --tail 50; fi
}

cmd_exec() {
  local hop=${1:-}
  shift || true
  [ -n "$hop" ] || die "usage: labyrinth exec <hop> [cmd...]"
  if [ $# -eq 0 ]; then dc exec "$hop" sh; else dc exec "$hop" "$@"; fi
}

# ---------------------------------------------------------------------------- usage
usage() {
  cat <<'EOF'
labyrinth — WireGuard multi-hop chain on macOS

USAGE:
  labyrinth init                generate keys + render configs (idempotent)
  labyrinth up                  build, compose up, wait for handshakes, run verify
  labyrinth status              snapshot of containers + handshakes + Mac side
  labyrinth test                run full diagnostic recipe (asserts on results)
  labyrinth selectivity         show current selectivity
  labyrinth selectivity MODE    switch live; MODE = all | destinations | off
  labyrinth logs [hop]          docker compose logs (default: all hops)
  labyrinth exec HOP [cmd ...]  docker compose exec; no cmd → interactive shell
  labyrinth down                stop containers + tear down Mac wg (keys preserved)
  labyrinth clean               down + remove state dir + remove image

STATE:
  ~/.config/labyrinth/   keys/, rendered/ (compose + wg confs)

CONFIG:
  edit hops.conf in this dir to retune IPs/ports/selectivity

NOTES:
  Mac is the entry hop (utun via wg-quick + wireguard-go). 2 containers (middle, exit).
  Selectivity = off (default) is safe: chain runs, Mac uses normal routing.
  Selectivity = all is a kill-switch: chain breaks → all Mac traffic dies.
EOF
}

# ---------------------------------------------------------------------------- dispatch
main() {
  local cmd=${1:-}
  shift || true
  case "$cmd" in
    init)         preflight; cmd_init ;;
    build)        preflight; cmd_build ;;
    up)           preflight; cmd_up ;;
    down)         preflight; cmd_down ;;
    clean)        preflight; cmd_clean ;;
    status)       preflight; cmd_status ;;
    test)         preflight; cmd_test ;;
    selectivity)  preflight; cmd_selectivity "$@" ;;
    logs)         preflight; cmd_logs "$@" ;;
    exec)         preflight; cmd_exec "$@" ;;
    -h|--help|help|"") usage ;;
    *)            err "unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
